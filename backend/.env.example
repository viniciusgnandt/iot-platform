# Server Configuration
PORT=3001
NODE_ENV=development

# Cache Configuration (seconds)
CACHE_TTL_SENSORS=300
CACHE_TTL_CITIES=600
CACHE_TTL_RANKING=600

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# External API Configuration
OPENSENSEMAP_BASE_URL=https://api.opensensemap.org
SENSOR_COMMUNITY_BASE_URL=https://data.sensor.community/airrohr/v1/filter

# OpenWeather API (optional fallback)
OPENWEATHER_API_KEY=your_api_key_here
OPENWEATHER_BASE_URL=https://api.openweathermap.org/data/2.5

# BreezoMeter API (optional, for air quality in major cities)
BREEZOMETER_API_KEY=your_api_key_here

# AQICN API (optional, for air quality data from World Air Quality Index)
# Get free API key at: https://aqicn.org/api/
AQICN_API_KEY=your_api_key_here

# Sensor Fetch Limits (to avoid excessive API calls)
MAX_SENSORS_PER_SOURCE=200
SENSOR_MAX_AGE_HOURS=2

# CORS
CORS_ORIGIN=http://localhost:5173

# Database Configuration (MongoDB)
MONGO_URI=mongodb://localhost:27017/iot_platform
MONGO_ENABLED=true

# Cache Configuration (Redis)
REDIS_URL=redis://localhost:6379
REDIS_ENABLED=true
