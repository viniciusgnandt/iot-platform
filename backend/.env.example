# ============================================================================
# IoT Environmental Platform - Backend Configuration
# ============================================================================

# Server Configuration
PORT=3001
NODE_ENV=production

# CORS
CORS_ORIGIN=http://localhost

# ============================================================================
# CACHE CONFIGURATION (TTL in seconds)
# ============================================================================
CACHE_TTL_SENSORS=300          # 5 minutes
CACHE_TTL_CITIES=600           # 10 minutes
CACHE_TTL_RANKING=600          # 10 minutes

# ============================================================================
# MONGODB ATLAS (Cloud Database - Only Storage)
# ============================================================================
MONGO_ENABLED=true
MONGO_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/?appName=APP_NAME

# ============================================================================
# EXTERNAL SENSOR APIs (All FREE - no API keys needed)
# ============================================================================

# OpenSenseMap (EU sensors)
OPENSENSEMAP_BASE_URL=https://api.opensensemap.org

# Sensor.Community (Global PM sensors)
SENSOR_COMMUNITY_BASE_URL=https://data.sensor.community/airrohr/v1/filter

# OpenWeather (optional - requires API key)
OPENWEATHER_API_KEY=your_api_key_here
OPENWEATHER_BASE_URL=https://api.openweathermap.org/data/2.5

# BreezoMeter (optional - requires API key)
BREEZOMETER_API_KEY=your_api_key_here

# AQICN (optional - free API key at https://aqicn.org/api/)
AQICN_API_KEY=your_api_key_here

# ============================================================================
# SENSOR FETCH LIMITS
# ============================================================================
MAX_SENSORS_PER_SOURCE=200
SENSOR_MAX_AGE_HOURS=2

# ============================================================================
# RATE LIMITING
# ============================================================================
RATE_LIMIT_WINDOW_MS=60000     # 1 minute window
RATE_LIMIT_MAX_REQUESTS=100    # max 100 requests per window
